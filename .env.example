# narrative-playlist-agent — .env.example
# Copia este archivo como .env y completa tus valores
# NUNCA commitees el archivo .env al repositorio

# ── LLM Provider ──────────────────────────────────────
LLM_PROVIDER=groq                        # groq | openai | anthropic

GROQ_API_KEY=your_groq_api_key_here      # https://console.groq.com
OPENAI_API_KEY=your_openai_key_here      # Opcional

# ── Spotify (solo para v3 — publicar playlist) ────────
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback

# ── Configuración del agente ──────────────────────────
MAX_TRACKS_PER_PLAYLIST=20
MAX_RETRY_ATTEMPTS=3
DEFAULT_TRACKS_PER_PHASE=3
